ignore:
  # Auto-created by Azure
  - resource_type: "Microsoft.Network/networkWatchers"
    reason: "Auto-created by Azure in each region, not IaC-managed"

  # Landing Zone infrastructure (deployed separately)
  - resource_type: "Microsoft.Network/virtualNetworks"
    reason: "VNets are part of LZ pattern, referenced by vm.bicep via 'existing' keyword"

  - resource_type: "Microsoft.Network/virtualNetworks/subnets"
    reason: "Subnets are part of LZ pattern, managed as part of VNet deployment"

  # Auto-managed by VMs (child resources)
  - resource_type: "Microsoft.Compute/disks"
    reason: "OS/data disks are auto-created and managed by VMs, not separately defined in IaC"

  - resource_type: "Microsoft.OperationalInsights/workspaces"
    reason: "Auto-created by Azure Defender/Monitor, not explicitly managed in IaC"

  - resource_type: "microsoft.insights/actiongroups"
    resource_name: ".*Smart Detection.*"
    reason: "Auto-created by Application Insights Smart Detection feature"

  # Parameter expression drift (expected differences)
  - resource_type: "Microsoft.Compute/virtualMachines"
    reason: "Parameter expressions in tags.environment resolve at deployment time"

  - resource_type: "Microsoft.Network/networkInterfaces"
    reason: "Parameter-based names resolve at deployment time"

  - resource_type: "Microsoft.RecoveryServices/vaults"
    reason: "API version differences are metadata, not functional drift"
