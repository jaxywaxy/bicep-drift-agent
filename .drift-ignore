ignore:
  # Auto-created by Azure
  - resource_type: "Microsoft.Network/networkWatchers"
    reason: "Auto-created by Azure in each region, not IaC-managed"

  # NOTE (Phase 4): platform network-fabric ignores (virtualNetworks,
  # virtualNetworks/subnets, networkSecurityGroups, routeTables) have been MOVED
  # OUT of this universal baseline into each *workload* landing zone's own
  # .drift-ignore. They are referenced-as-existing in a workload LZ (ignore) but
  # MANAGED in a platform LZ (surface) - so they must be per-LZ, not global.

  # Auto-managed by VMs and Compute
  - resource_type: "Microsoft.Compute/disks"
    reason: "OS/data disks are auto-created and managed by VMs, not separately defined in IaC"

  - resource_type: "Microsoft.Compute/virtualMachines/extensions"
    reason: "VM extensions auto-managed by VMs, not separately defined in Bicep"

  - resource_type: "Microsoft.Compute/virtualMachineScaleSets"
    reason: "VMSS auto-created by AKS node pools, managed separately"

  # AKS auto-managed resources. Scoped to extra_in_azure ONLY: pools declared
  # inline in the cluster's agentPoolProfiles (system pools) surface as extra
  # children, but a separately-DECLARED agentPools child must still surface
  # missing_in_azure (deleted pool) and property_drift (scaled/re-sized pool).
  - resource_type: "Microsoft.ContainerService/managedClusters/agentPools"
    drift_type: "extra_in_azure"
    reason: "Inline/system agent pools surface as extra children; managed via the cluster"

  # Scoped to extra_in_azure ONLY: the concern is auto-created LBs/PIPs that appear
  # as unmanaged extras. An IaC-DECLARED load balancer or public IP must still surface
  # property_drift (e.g. a probe/rule/SKU change) and missing_in_azure (deletion) —
  # a bare type match would silence those too.
  - resource_type: "Microsoft.Network/loadBalancers"
    drift_type: "extra_in_azure"
    reason: "Load balancers auto-created by AKS and App Services"

  - resource_type: "Microsoft.Network/publicIPAddresses"
    drift_type: "extra_in_azure"
    reason: "Public IPs auto-created by LBs, App Gateways, or referenced as existing"


  # NOTE: storage blob/file services and CONTAINERS/SHARES are deliberately NOT
  # ignored anymore - they're ARM-REST-expanded and compared. A hand-added or
  # made-public container is exactly the drift this exists to catch. The
  # tableServices/queueServices defaults (not yet expanded) stay ignored.
  - resource_type: "Microsoft.Storage/storageAccounts/tableServices"
    reason: "Table services auto-created with storage account (not yet expanded)"

  - resource_type: "Microsoft.Storage/storageAccounts/queueServices"
    reason: "Queue services auto-created with storage account (not yet expanded)"

  # SQL Server auto-managed resources
  - resource_type: "Microsoft.Sql/servers/databases"
    resource_name: "master"
    reason: "Master database auto-created with SQL Server"

  - resource_type: "Microsoft.Sql/servers/auditingSettings"
    reason: "Auditing settings auto-configured by policies"

  - resource_type: "Microsoft.Sql/servers/securityAlertPolicies"
    reason: "Security policies auto-configured by Azure Defender"

  # App Service auto-managed resources
  - resource_type: "Microsoft.Web/sites/slots"
    reason: "Deployment slots auto-created for certain App Service configurations"

  # NOTE: Microsoft.Web/sites/config is deliberately NOT ignored anymore -
  # config/web and appsettings are expanded and compared (appsettings as key
  # sets, values redacted). Portal setting flips are canonical workload drift.

  - resource_type: "Microsoft.Web/sites/extensions"
    reason: "Site extensions auto-managed by App Service"

  # System/Compliance resources
  # Note: Locks defined in IaC (Bicep) are now managed and should be detected
  # Lock removal is a critical security event that must trigger drift alerts

  # NOTE: Microsoft.Authorization/roleAssignments is deliberately NOT ignored
  # (it used to be, from before RBAC drift detection existed - the blanket
  # ignore would swallow every out-of-band grant the feature exists to catch).
  # Known automation-created assignments should be ignored per-LZ by role or
  # principal instead: drift names are "<RoleName> -> <PrincipalType>:<id>".

  # Monitoring/Diagnostics
  # Only ignore EXTRA workspaces (auto-created by Defender/Monitor and not in IaC).
  # A missing_in_azure workspace means an IaC-managed workspace was deleted - that
  # is real drift and must NOT be suppressed.
  - resource_type: "Microsoft.OperationalInsights/workspaces"
    drift_type: "extra_in_azure"
    reason: "Extra workspace auto-created by Azure Defender/Monitor, not managed in IaC"

  - resource_type: "microsoft.insights/actiongroups"
    resource_name: ".*Smart Detection.*"
    reason: "Auto-created by Application Insights Smart Detection feature"

  # NOTE: Microsoft.Insights/diagnosticSettings is deliberately NOT ignored
  # anymore - settings are expanded per resource and compared; a deleted one is
  # a silenced audit/SIEM feed. Policy-created settings are handled by Phase 3
  # attribution (policy-enforced = expected), not by a blanket ignore.

  # Tag drift on VMs (parameter expressions in tags resolve at deployment time)
  - resource_type: "Microsoft.Compute/virtualMachines"
    drift_type: "tags"
    reason: "Parameter expressions in tags resolve at deployment time, not functional drift"

  # Network interfaces (auto-managed or parameter-based)
  - resource_type: "Microsoft.Network/networkInterfaces"
    reason: "NICs are created by VMs or parameter expressions, config drift only"

  # API versions (metadata, not functional)
  - resource_type: "Microsoft.RecoveryServices/vaults"
    drift_type: "property_drift"
    reason: "API version differences are metadata - property drift only; a deleted/added vault is still real drift"

  # Recovery Services child resources with unresolvable parameter expressions
  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics/replicationProtectionContainers"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationFabrics/replicationProtectionContainers/replicationProtectionContainerMappings"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationPolicies"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupstorageconfig"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupFabrics/protectionContainers"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupFabrics/protectionContainers/protectedItems"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupPolicies"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/backupconfig"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.RecoveryServices/vaults/replicationAlertSettings"
    reason: "Child resource with unresolvable parameter expressions in name"

  - resource_type: "Microsoft.Network/privateEndpoints/privateDnsZoneGroups"
    reason: "Child resource with unresolvable parameter expressions in name"

  # A records inside privatelink.* zones are auto-created by a private endpoint's
  # DNS zone group (Azure manages them), so they appear as extras. Scoped to
  # extra_in_azure and the privatelink.* zone so a hand-declared record in such a
  # zone would still surface as property/missing drift.
  - resource_type: "Microsoft.Network/privateDnsZones/A"
    resource_name: "privatelink.*"
    drift_type: "extra_in_azure"
    reason: "A records in privatelink.* zones are auto-created by private endpoint DNS zone groups"

  # Optional resource properties (not defined in Bicep)
  # These appear in Azure but weren't explicitly set in template
  - resource_type: "Microsoft.RecoveryServices/vaults"
    drift_type: "property_drift"
    reason: "Optional properties (sku fields, tags added by Azure) ignored if not in Bicep - property drift only"

  # NARROWED from a blanket property_drift ignore: only the agentPoolProfiles
  # array is genuinely noisy (separately-declared agentPools children materialize
  # as added elements; counts move under autoscale) - pools are compared via the
  # expanded agentPools children instead. Security posture (enableRBAC,
  # apiServerAccessProfile, networkProfile, disableLocalAccounts) now SURFACES.
  - resource_type: "Microsoft.ContainerService/managedClusters"
    property: "properties.agentPoolProfiles"
    reason: "Pool state duplicated into the parent's agentPoolProfiles array; pools compared via agentPools children"

  # API Management auto-managed resources
  - resource_type: "Microsoft.ApiManagement/service/groups"
    reason: "Built-in groups (administrators, developers, guests) auto-created by API Management"

  - resource_type: "Microsoft.ApiManagement/service/products"
    reason: "Built-in products (Starter, Unlimited) auto-created by API Management"

  - resource_type: "Microsoft.ApiManagement/service/loggers"
    reason: "Default logger auto-created by API Management"

  - resource_type: "Microsoft.ApiManagement/service/diagnostics"
    reason: "Diagnostic settings auto-created by API Management"

  - resource_type: "Microsoft.ApiManagement/service/apis/policies"
    reason: "API policies often managed via portal or Azure Policy, not Bicep"

  - resource_type: "Microsoft.ApiManagement/service/policies"
    reason: "Service-level policies often managed via portal, not Bicep"

  - resource_type: "Microsoft.ApiManagement/service/tags"
    reason: "Tags auto-created and managed by API Management"

  - resource_type: "Microsoft.ApiManagement/service/operationTags"
    reason: "Operation tags auto-managed by API Management"

  # Event Hub resources with unresolvable parameter-based names
  # Child resources and namespaces cannot be matched/compared due to uniqueString()
  # They are deployed correctly but drift detection has matching/property visibility issues
  - resource_type: "Microsoft.EventHub/namespaces"
    drift_type: "property_drift"
    reason: "Namespace properties not fully exposed by Azure API - property drift only; a deleted/added namespace is still real drift"

  # NOTE: EventHub child resources (eventhubs, authorizationRules, consumer
  # groups) are deliberately NOT ignored anymore - they're expanded via ARM
  # REST and placeholder-named parents smart-match since PR #185.

  # Log Analytics resources with unresolvable parameter names
  # Custom tables and solutions with parameter-based parent names cannot be reliably matched
  - resource_type: "Microsoft.OperationalInsights/workspaces/tables"
    reason: "Child resource with parent name containing unresolved parameter expressions"

  - resource_type: "Microsoft.OperationalInsights/workspaces/savedSearches"
    reason: "Child resource with parent name containing unresolved parameter expressions"

  - resource_type: "Microsoft.OperationalInsights/workspaces/solutions"
    reason: "Child resource with parent name containing unresolved parameter expressions"

  # NOTE: Key Vault networkAcls is deliberately NOT ignored (it used to be).
  # Null-vs-default noise is handled in the comparator instead (deployed-side
  # default injection in property_drift.py), so real ACL drift - a
  # defaultAction flip or a hand-added ipRule - surfaces as critical drift.

  - resource_type: "Microsoft.KeyVault/vaults"
    property: "properties.integrationAccount"
    reason: "integrationAccount is optional; null on both sides is not functional drift"

  # Logic App optional properties
  - resource_type: "Microsoft.Logic/workflows"
    property: "properties.integrationAccount"
    reason: "integrationAccount is optional and may not be returned by Azure API when not set"
